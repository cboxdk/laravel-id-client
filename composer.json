{
    "name": "cboxdk/laravel-id-client",
    "description": "Laravel/PHP consumer SDK for Cbox ID",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.5 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Cbox\\Id\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\Id\\Client\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cbox\\Id\\Client\\ClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
